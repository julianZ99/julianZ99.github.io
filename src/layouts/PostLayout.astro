---
import { SITE_TITLE } from '../consts';
import BackgroundAnimation from '../components/BackgroundAnimation.astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	githubRepo?: string;
	heroImage?: any;
	lastCommitDate?: Date | null;
	hideTitle?: boolean;
}

const { title, description, pubDate, heroImage, lastCommitDate, githubRepo, hideTitle } = Astro.props;
const tabTitle = `${SITE_TITLE} - ${title}`;
---

<html lang="en">
	<head>
		<BaseHead title={tabTitle} description={description} />

	</head>

	<body>
		<BackgroundAnimation />
		<Header />
		<main>
			<article>
				{
					heroImage && (
						<Fragment>
							<div class="hero-image">
								<img width={1020} height={510} src={heroImage} alt="" />
							</div>
							<hr />
						</Fragment>
					)
				}
				<div class="content">
					<div class="title">
						{!hideTitle && <h1>{title}</h1>}
						<p class="description">{description}</p>
						<div class="meta">
							{
								githubRepo && (
									<a class="repo-link" href={`https://github.com/${githubRepo}`}>{githubRepo}</a>
								)
							}
							<div class="date">
								<div>Published <FormattedDate date={pubDate} /></div>
								{
									lastCommitDate && (
										<div>Last commit <FormattedDate date={lastCommitDate} /></div>
									)
								}
							</div>
						</div>
					</div>
				</div>
				<hr />
				<div class="content">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
