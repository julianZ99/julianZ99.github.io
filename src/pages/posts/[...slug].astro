---
import { getCollection, render } from 'astro:content';
import { getLastCommitDate } from '../../lib/github';
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
	const posts = await getCollection('posts');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}

const post = Astro.props;
const { Content } = await render(post);

let lastCommitDate = post.data.updatedDate ?? null;
if (post.data.githubRepo) {
	lastCommitDate = await getLastCommitDate(post.data.githubRepo) ?? lastCommitDate;
}
const heroImage = post.data.heroImage ?? null;
---

<PostLayout {...post.data} {heroImage} lastCommitDate={lastCommitDate}>
	<Content />
</PostLayout>
