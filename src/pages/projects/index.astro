---
import { getCollection } from 'astro:content';
import BackgroundAnimation from '../../components/BackgroundAnimation.astro';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { getProjectImage } from '../../lib/project-images';

const projects = (await getCollection('projects')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${SITE_TITLE} - Projects`} description={SITE_DESCRIPTION} />
		<script src="/src/scripts/size-entries.js" data-astro-rerun></script>
	</head>
	<body>
		<BackgroundAnimation />
		<Header />
		<main>
			<section>
				<ul>
					{
						projects.map((project) => {
							const icon = getProjectImage(project.data.githubRepo, 'icon');
							return (
								<li>
									<a href={`/projects/${project.id}/`} class:list={{ 'no-icon': !icon }}>
										{icon && (
											<img width={360} height={180} src={icon} alt="" onerror="this.style.display='none'" />
										)}
										<div class="info">
											<h4 class="title">{project.data.title}</h4>
											<p class="description">{project.data.description}</p>
											<div class="meta">
												{project.data.githubRepo && (
													<span class="repo-label">{project.data.githubRepo}</span>
												)}
												<div class="dates">
													<div class="date">
														Published <FormattedDate date={project.data.pubDate} />
													</div>
													{project.data.updatedDate && (
														<div class="date">
															Last commit <FormattedDate date={project.data.updatedDate} />
														</div>
													)}
												</div>
											</div>
										</div>
									</a>
								</li>
							);
						})
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
