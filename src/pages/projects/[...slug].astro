---
import { getCollection, render } from 'astro:content';
import { getLastCommitDate } from '../../lib/github';
import { getProjectImage } from '../../lib/project-images';
import ProjectLayout from '../../layouts/ProjectLayout.astro';

export async function getStaticPaths() {
	const projects = await getCollection('projects');
	return projects.map((project) => ({
		params: { slug: project.id },
		props: project,
	}));
}

const project = Astro.props;
const { Content } = await render(project);

let lastCommitDate = project.data.updatedDate ?? null;
if (project.data.githubRepo) {
	lastCommitDate = await getLastCommitDate(project.data.githubRepo) ?? lastCommitDate;
}
const heroImage = getProjectImage(project.data.githubRepo, 'banner');
---

<ProjectLayout {...project.data} {heroImage} lastCommitDate={lastCommitDate} hideTitle={true}>
	<Content />
</ProjectLayout>
