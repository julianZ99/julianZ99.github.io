---
import BackgroundAnimation from "../components/BackgroundAnimation.astro";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${SITE_TITLE} - Home`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<BackgroundAnimation />
		<Header />
		<main>
			<div class="content">
				<div class="title">
					<h1 data-typewriter>julianZ99</h1>
				</div>
				<p>
					This site is a collection of my public projects & software experiments.
				</p>
				<p>
					I'll also try to write here some notes about topics that interest me, and the things I
					learn along the way.
				</p>
			</div>
		</main>
		<Footer />
	</body>
</html>
